# Google Cloud Platform (GCP) Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Authentication Method: 'token' or 'serviceAccount'
GCP_AUTH_TYPE=token

# Option A: Paste short-lived Google OAuth2 Access Token
# (Generate via: gcloud auth print-access-token)
GCP_ACCESS_TOKEN=ya29.c.Ko0BvQ...

# Option B: Path to your Google Service Account Credentials JSON file (e.g. /path/to/key.json)
# Or paste the raw JSON contents directly into GCP_SERVICE_ACCOUNT_KEY
GOOGLE_APPLICATION_CREDENTIALS=
GCP_SERVICE_ACCOUNT_KEY=

# Set to 'false' to disable the simulated sandbox and run live calls on load
SANDBOX_MODE=true
